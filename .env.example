# Database Configuration
DATABASE_URL=postgres://seeku:seeku_dev_password@localhost:5432/seeku
POSTGRES_USER=seeku
POSTGRES_PASSWORD=seeku_dev_password
POSTGRES_DB=seeku

# AI Provider Configuration (SiliconFlow / OpenAI Compatible)
SILICONFLOW_API_KEY=YOUR_API_KEY_HERE

# StepFun (阶跃星辰) Official API — used for chat/planner when set
# STEPFUN_API_KEY=YOUR_STEPFUN_API_KEY_HERE
# STEPFUN_BASE_URL=https://api.stepfun.com/v1
# STEPFUN_CHAT_MODEL=step-3.5-flash-2603

# Jina Reader API (Optional, for anti-bot resilience)
JINA_API_KEY=YOUR_API_KEY_HERE

# API & Worker Configuration
API_PORT=3001
API_ADMIN_KEY=YOUR_ADMIN_SECRET_HERE
CORS_ORIGINS=http://localhost:3001
GITHUB_TOKEN=YOUR_API_KEY_HERE

# Graph Rerank Feature Flags (Phase 15)
# IMPORTANT: Default is DISABLED (0). Must explicitly set to 1 to enable.
# This prevents accidental enablement in production without explicit configuration.
SEEKU_GRAPH_RERANK_ENABLED=0
# SEEKU_GRAPH_MUTUAL_CONNECTION_BOOST=0.02
# SEEKU_GRAPH_DIRECT_NEIGHBOR_BOOST=0.08
# SEEKU_GRAPH_SAME_COMPONENT_BOOST=0  (disabled - 99.8% of graph is one giant component)
