{
  "name": "seeku",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:sync:bonjour": "pnpm --filter @seeku/worker sync:bonjour",
    "worker:sync:github": "pnpm --filter @seeku/worker sync:github",
    "worker:resolve-identities": "pnpm --filter @seeku/worker resolve-identities",
    "worker:store-evidence": "pnpm --filter @seeku/worker store-evidence",
    "api:start": "pnpm --filter @seeku/api start",
    "db:up": "docker compose --env-file .env -f infra/docker-compose.yml up -d",
    "db:down": "docker compose --env-file .env -f infra/docker-compose.yml down",
    "db:logs": "docker compose --env-file .env -f infra/docker-compose.yml logs -f",
    "db:generate": "pnpm --filter @seeku/db db:generate",
    "db:push": "pnpm --filter @seeku/db db:push",
    "db:migrate": "pnpm --filter @seeku/db db:migrate"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "dotenv": "^16.4.7",
    "turbo": "^2.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
