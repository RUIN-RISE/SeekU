{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@seeku/shared": ["packages/shared/src/index.ts"],
      "@seeku/db": ["packages/db/src/index.ts"],
      "@seeku/adapters": ["packages/adapters/src/index.ts"],
      "@seeku/worker": ["apps/worker/src/index.ts"],
      "@seeku/api": ["apps/api/src/index.ts"]
    }
  }
}
